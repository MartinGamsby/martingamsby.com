---
import PostList from './PostList.astro';
import Icon from './Icon.astro';
import type { IconName } from '../lib/icons';
import { t, type Lang } from '../i18n/ui';
import { getPosts, type Facet } from '../lib/blog';

interface Props {
  lang: Lang;
  doorKey: 'dev' | 'physics' | 'book' | 'music';
  facet: Facet;
  links?: { label: string; url: string; icon: IconName }[];
}

const { lang, doorKey, facet, links = [] } = Astro.props;
const tr = t(lang);
const posts = await getPosts(lang, facet);
---

<h1>{tr.doors[doorKey].title}</h1>
<p>{tr.doors[doorKey].blurb}</p>
{links.length > 0 && (
  <ul class="link-list">
    {links.map((l) => (
      <li><a href={l.url}><Icon name={l.icon} size={20} /><span>{l.label}</span></a></li>
    ))}
  </ul>
)}
<p>{tr.underConstruction}</p>
<PostList posts={posts} lang={lang} />
