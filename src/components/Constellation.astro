---
// Animated "everything is connected" node graph behind the hero + doors.
//
// Three kinds of node:
//   • boxes   — the gate cards + the title/subtitle. Rectangular "objects";
//               links attach to their BORDER, not their centre, so the whole
//               card reads as the star. Bigger box -> slower drift.
//   • socials — the social links, rendered as DOM chips (.sky-social) and placed
//               near the gate they belong to (data-facet) with a configurable
//               weight (data-weight -> size). Wired to their gate with a
//               facet-coloured line.
//   • stars   — the background field. Many, with a wide size spread so the gates
//               aren't the only big things.
//
// The DOM keeps its responsive layout (works without JS); this measures it and
// nudges each node via the `translate` property, which composes with the cards'
// :hover transform instead of clobbering it. Static under prefers-reduced-motion,
// paused when the tab is hidden, palette follows the active theme.
---

<div class="hero-sky" aria-hidden="true"><canvas></canvas></div>

<script>
  import { rectEdge, circEdge, orbitPoint } from '../lib/constellation-geometry';

  const sky = document.querySelector('.hero-sky');
  const canvas = sky?.querySelector('canvas');
  const ctx = canvas?.getContext('2d');

  if (sky && canvas && ctx) {
    const STAR_PALETTES = {
      dark: ['#38bdf8', '#a78bfa', '#fbbf24', '#f472b6'],
      light: ['#0284c7', '#7c3aed', '#b45309', '#db2777'],
    };
    const LINK_DIST = 132;        // star <-> star
    const STAR_REACH = 210;       // star <-> box border (a bit further, so neighbours show)
    const BOX_WEB = 460;          // box <-> box backbone
    const STAR_SOCIAL = 150;      // star <-> social chip
    const DRIFT_K = 1.9;          // angular speed = SPEED * DRIFT_K / size  (bigger = slower)
    const SPEED = 0.55;           // global drift-speed multiplier — lower = calmer
    const GATE_MARGIN = 14;       // keep social chips this far outside every card edge
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const clamp = (v, lo, hi) => Math.min(hi, Math.max(lo, v));

    let starPalette = STAR_PALETTES[document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light'];
    let stars = [];
    let boxes = [];      // gates + title/subtitle
    let socials = [];    // social chips
    let w = 0, h = 0, dpr = 1, raf = 0, t = 0;

    const socialsUl = document.querySelector('.sky-socials');
    socialsUl?.classList.add('is-floating'); // progressive enhancement: lift chips into the sky

    function facetColors() {
      const cs = getComputedStyle(document.documentElement);
      const v = (name, fb) => (cs.getPropertyValue(name).trim() || fb);
      const accent = v('--accent', '#a78bfa');
      return {
        dev: v('--c-dev', '#38bdf8'),
        physics: v('--c-physics', '#a78bfa'),
        book: v('--c-book', '#fbbf24'),
        music: v('--c-music', '#db2777'),
        everything: accent,
        text: accent,
      };
    }
    let fc = facetColors();

    // --- geometry helpers ---------------------------------------------------
    // rectEdge / circEdge / orbitPoint are shared with StarMap.astro — see
    // src/lib/constellation-geometry.ts.
    function inRect(b, px, py) {
      return Math.abs(px - b.x) <= b.hw && Math.abs(py - b.y) <= b.hh;
    }

    // --- measuring the DOM into nodes --------------------------------------
    function measureBoxes() {
      const field = sky.getBoundingClientRect();
      const list = [
        ...[...document.querySelectorAll('.hero h1, .hero p')].map((el) => ({ el, kind: 'text', facet: 'text' })),
        ...[...document.querySelectorAll('.door')].map((el) => ({ el, kind: 'gate', facet: el.dataset.facet })),
      ];
      boxes = list.map(({ el, kind, facet }) => {
        el.style.translate = '';
        const r = el.getBoundingClientRect();
        const size = Math.max(r.width, r.height);
        const ampX = Math.max(3.5, Math.min(8, 1400 / size));
        const rad = parseFloat(getComputedStyle(el).borderTopLeftRadius) || 0;
        return {
          el, kind, facet, rad,
          homeX: r.left - field.left + r.width / 2,
          homeY: r.top - field.top + r.height / 2,
          hw: r.width / 2,
          hh: r.height / 2,
          wv: SPEED * DRIFT_K / size,
          px: Math.random() * Math.PI * 2,
          py: Math.random() * Math.PI * 2,
          ampX, ampY: ampX * 0.7,
          c: fc[facet] || fc.text,
          x: r.left - field.left + r.width / 2,
          y: r.top - field.top + r.height / 2,
        };
      });
    }

    function layoutSocials() {
      const chips = [...document.querySelectorAll('.sky-social')];
      if (!chips.length) { socials = []; return; }

      // Horizontal play space is the whole visible viewport (the sky is
      // full-bleed), not just the narrow content column — that gives real
      // margins left/right of the cards for chips to live in. Vertically we
      // stay within the gates' band.
      const skyRect = sky.getBoundingClientRect();
      const edge = 16;
      const leftBound = -skyRect.left + edge;
      const rightBound = innerWidth - skyRect.left - edge;
      let maxY = -Infinity;
      for (const b of boxes) maxY = Math.max(maxY, b.homeY + b.hh);
      const fallbackGate = boxes.find((b) => b.kind === 'gate');

      socials = chips.map((el) => {
        const facet = el.dataset.facet || 'everything';
        const weight = parseFloat(el.dataset.weight || '1');
        const r = el.getBoundingClientRect();
        const radius = (r.width || 32 * weight) / 2;
        const gate = boxes.find((b) => b.kind === 'gate' && b.facet === facet) || fallbackGate;
        // Float at the speed of a mid-size object (floored), not their tiny size,
        // and with a small amplitude — otherwise the chips whip around.
        const eff = Math.max(radius * 2, 200);
        const ampX = 5;
        return {
          el, facet, weight, gate, radius,
          wv: SPEED * DRIFT_K / eff,
          px: Math.random() * Math.PI * 2,
          py: Math.random() * Math.PI * 2,
          ampX, ampY: ampX * 0.8,
          c: fc[facet] || fc.everything,
          homeX: gate.homeX, homeY: gate.homeY, x: 0, y: 0,
        };
      });

      const placed = [];
      const fits = (x, y, radius) => {
        if (x < leftBound + radius || x > rightBound - radius) return false;
        if (y < 12 + radius || y > maxY - radius) return false;
        for (const b of boxes) {
          // true distance from the chip to the card rect (corners included)
          const ddx = Math.max(b.homeX - b.hw - x, 0, x - (b.homeX + b.hw));
          const ddy = Math.max(b.homeY - b.hh - y, 0, y - (b.homeY + b.hh));
          if (Math.hypot(ddx, ddy) < radius + GATE_MARGIN) return false;
        }
        for (const p of placed) {
          if (Math.hypot(x - p.x, y - p.y) < radius + p.radius + 10) return false;
        }
        return true;
      };

      // orbitPoint (the rounded outline `d` px outside a box) is shared — see
      // src/lib/constellation-geometry.ts. A chip walks its gate's orbit until it finds
      // a spot clear of every card, placed chip, and the screen edge — widening the
      // orbit only if the whole ring is blocked.
      const N = 30;
      for (const s of socials) {
        const g = s.gate, base = GATE_MARGIN + s.radius;
        const gBox = { x: g.homeX, y: g.homeY, hw: g.hw, hh: g.hh };
        const phase = Math.random();
        let best = null;
        for (let ring = 0; ring < 14 && !best; ring++) {
          const d = base + ring * (s.radius * 2 + 8);
          for (let k = 0; k < N && !best; k++) {
            const pt = orbitPoint(gBox, d, phase + k / N);
            if (fits(pt.x, pt.y, s.radius)) best = pt;
          }
        }
        if (!best) best = {
          x: clamp(g.homeX, leftBound + s.radius, rightBound - s.radius),
          y: clamp(g.homeY - g.hh - base, 12 + s.radius, maxY - s.radius),
        };
        s.homeX = best.x; s.homeY = best.y;
        placed.push({ x: best.x, y: best.y, radius: s.radius });
      }

      for (const s of socials) {
        s.x = s.homeX; s.y = s.homeY;
        s.el.style.left = `${s.homeX.toFixed(1)}px`;
        s.el.style.top = `${s.homeY.toFixed(1)}px`;
      }
    }

    function resize() {
      const rect = sky.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      dpr = Math.min(devicePixelRatio || 1, 2);
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const count = Math.min(175, Math.round((w * h) / 9000));
      stars = Array.from({ length: count }, () => {
        const i = Math.floor(Math.random() * starPalette.length);
        return {
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.34,
          vy: (Math.random() - 0.5) * 0.34,
          i,
          c: starPalette[i],
          rseed: Math.random(),
          hseed: Math.random(),
          r: 1, ring: false,
        };
      });
      measureBoxes();
      layoutSocials();
      // Continuous size spread, from tiny dots up to half a base-weight social
      // chip (always smaller than an icon). Larger stars are progressively more
      // likely to be drawn as hollow rings, with a mixed band in the middle so
      // there's no break between "small filled dot" and "big hollow circle".
      const baseR = socials.length ? socials[0].radius / socials[0].weight : 16;
      const rMin = 0.7, rMax = baseR * 0.5;
      for (const n of stars) {
        n.r = rMin + Math.pow(n.rseed, 2.4) * (rMax - rMin);
        n.ring = n.hseed < Math.min(1, Math.max(0, (n.r - 3) / 4));
      }
    }

    function drawLink(x1, y1, x2, y2, color, alpha, width) {
      ctx.globalAlpha = alpha;
      ctx.strokeStyle = color;
      ctx.lineWidth = width;
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.lineTo(x2, y2);
      ctx.stroke();
    }

    function frame(advance) {
      if (advance) t++;
      ctx.clearRect(0, 0, w, h);

      for (const n of stars) {
        if (advance) {
          n.x += n.vx; n.y += n.vy;
          if (n.x < 0 || n.x > w) n.vx *= -1;
          if (n.y < 0 || n.y > h) n.vy *= -1;
        }
      }
      for (const b of boxes) {
        const dx = b.ampX * Math.sin(t * b.wv + b.px);
        const dy = b.ampY * Math.cos(t * b.wv * 0.85 + b.py);
        b.x = b.homeX + dx; b.y = b.homeY + dy;
        if (advance) b.el.style.translate = `${dx.toFixed(2)}px ${dy.toFixed(2)}px`;
      }
      for (const s of socials) {
        const dx = s.ampX * Math.sin(t * s.wv + s.px);
        const dy = s.ampY * Math.cos(t * s.wv * 0.9 + s.py);
        s.x = s.homeX + dx; s.y = s.homeY + dy;
        if (advance) s.el.style.translate = `${dx.toFixed(2)}px ${dy.toFixed(2)}px`;
      }

      // star <-> star
      for (let a = 0; a < stars.length; a++) {
        for (let b = a + 1; b < stars.length; b++) {
          const dx = stars[a].x - stars[b].x, dy = stars[a].y - stars[b].y;
          const d = Math.hypot(dx, dy);
          if (d < LINK_DIST) drawLink(stars[a].x, stars[a].y, stars[b].x, stars[b].y, stars[a].c, (1 - d / LINK_DIST) * 0.32, 1);
        }
      }

      // star <-> box border (skip stars hidden under the box)
      for (const b of boxes) {
        for (const n of stars) {
          if (inRect(b, n.x, n.y)) continue;
          const d = Math.hypot(b.x - n.x, b.y - n.y);
          if (d < STAR_REACH) {
            const e = rectEdge(b, n.x, n.y);
            drawLink(e.x, e.y, n.x, n.y, b.c, (1 - d / STAR_REACH) * 0.5, 1);
          }
        }
      }

      // box <-> box backbone (border to border, so it shows in the gaps)
      for (let a = 0; a < boxes.length; a++) {
        for (let b = a + 1; b < boxes.length; b++) {
          const d = Math.hypot(boxes[a].x - boxes[b].x, boxes[a].y - boxes[b].y);
          if (d < BOX_WEB) {
            const e1 = rectEdge(boxes[a], boxes[b].x, boxes[b].y);
            const e2 = rectEdge(boxes[b], boxes[a].x, boxes[a].y);
            drawLink(e1.x, e1.y, e2.x, e2.y, boxes[a].c, (1 - d / BOX_WEB) * 0.38, 1.1);
          }
        }
      }

      // social <-> its gate, and social <-> nearby stars
      for (const s of socials) {
        if (s.gate) {
          const e1 = circEdge(s, s.gate.x, s.gate.y);
          const e2 = rectEdge(s.gate, s.x, s.y);
          drawLink(e1.x, e1.y, e2.x, e2.y, s.c, 0.6, 1.3);
        }
        for (const n of stars) {
          const d = Math.hypot(s.x - n.x, s.y - n.y);
          if (d < STAR_SOCIAL) {
            const e = circEdge(s, n.x, n.y);
            drawLink(e.x, e.y, n.x, n.y, s.c, (1 - d / STAR_SOCIAL) * 0.4, 1);
          }
        }
      }

      // star dots — small ones filled, the occasional big one a hollow ring
      for (const n of stars) {
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        if (n.ring) {
          ctx.globalAlpha = 0.7;
          ctx.lineWidth = Math.max(1, n.r * 0.16);
          ctx.strokeStyle = n.c;
          ctx.stroke();
        } else {
          ctx.globalAlpha = 0.9;
          ctx.fillStyle = n.c;
          ctx.fill();
        }
      }

      // a faint glow under each social chip / gate core, in its facet hue
      for (const s of socials) {
        ctx.save();
        ctx.globalAlpha = 0.22;
        ctx.shadowColor = s.c; ctx.shadowBlur = 14;
        ctx.fillStyle = s.c;
        ctx.beginPath(); ctx.arc(s.x, s.y, s.radius * 0.55, 0, Math.PI * 2); ctx.fill();
        ctx.restore();
      }
      for (const b of boxes) {
        if (b.kind !== 'gate') continue;
        ctx.save();
        ctx.globalAlpha = 0.7;
        ctx.shadowColor = b.c; ctx.shadowBlur = 14;
        ctx.fillStyle = b.c;
        ctx.beginPath(); ctx.arc(b.x, b.y, 2.6, 0, Math.PI * 2); ctx.fill();
        ctx.restore();
      }

      ctx.globalAlpha = 1;
    }

    function loop() { frame(true); raf = requestAnimationFrame(loop); }

    function start() {
      cancelAnimationFrame(raf);
      if (reduced) {
        for (let i = 0; i < 60; i++) for (const n of stars) { n.x += n.vx; n.y += n.vy; }
        frame(false);
      } else {
        loop();
      }
    }

    resize();
    start();

    addEventListener('resize', () => { resize(); start(); });
    document.fonts?.ready.then(() => { resize(); if (reduced) frame(false); });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) cancelAnimationFrame(raf);
      else start();
    });
    new MutationObserver(() => {
      starPalette = STAR_PALETTES[document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light'];
      fc = facetColors();
      for (const n of stars) n.c = starPalette[n.i];
      for (const b of boxes) b.c = fc[b.facet] || fc.text;
      for (const s of socials) s.c = fc[s.facet] || fc.everything;
      if (reduced) frame(false);
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  }
</script>
