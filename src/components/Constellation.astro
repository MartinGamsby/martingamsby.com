---
// Animated "everything is connected" node graph behind the hero + doors.
// The gate cards and the title/subtitle are folded in as *anchor* stars:
// big, slow-drifting nodes the small background stars link to. Bigger anchors
// drift slower (title slowest, gates gentle, background stars fastest).
// Pure canvas, no deps; static single frame under prefers-reduced-motion;
// pauses when the tab is hidden; palette follows the active theme.
// The DOM keeps its responsive CSS-grid layout (works without JS); this only
// measures it and nudges each anchor via the `translate` property, which
// composes with the cards' :hover transform instead of clobbering it.
---

<div class="hero-sky" aria-hidden="true"><canvas></canvas></div>

<script>
  const sky = document.querySelector('.hero-sky');
  const canvas = sky?.querySelector('canvas');
  const ctx = canvas?.getContext('2d');

  if (sky && canvas && ctx) {
    const PALETTES = {
      dark: ['#38bdf8', '#a78bfa', '#fbbf24', '#f472b6'],
      light: ['#0284c7', '#7c3aed', '#b45309', '#db2777'],
    };
    const LINK_DIST = 130;        // star <-> star
    const ANCHOR_LINK = 172;      // star <-> gate reach
    const ANCHOR_WEB = 420;       // gate <-> gate backbone
    const DRIFT_K = 1.9;          // angular speed = DRIFT_K / size  (bigger = slower)
    const ANCHOR_SEL = '.hero h1, .hero p, .door';
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    let palette = PALETTES[document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light'];
    let nodes = [];
    let anchors = [];
    let w = 0;
    let h = 0;
    let dpr = 1;
    let raf = 0;
    let t = 0;

    function measureAnchors() {
      const field = sky.getBoundingClientRect();
      anchors = [...document.querySelectorAll(ANCHOR_SEL)].map((el, idx) => {
        el.style.translate = ''; // clear so we read the untranslated home position
        const r = el.getBoundingClientRect();
        const size = Math.max(r.width, r.height);
        const i = idx % palette.length;
        const ampX = Math.max(5, Math.min(11, 1500 / size));
        return {
          el,
          homeX: r.left - field.left + r.width / 2,
          homeY: r.top - field.top + r.height / 2,
          wv: DRIFT_K / size,                 // bigger anchor -> slower orbit
          px: Math.random() * Math.PI * 2,
          py: Math.random() * Math.PI * 2,
          ampX,
          ampY: ampX * 0.7,
          i,
          c: palette[i],
          r: Math.max(2.2, Math.min(4, size / 64)),
          x: r.left - field.left + r.width / 2,
          y: r.top - field.top + r.height / 2,
        };
      });
    }

    function resize() {
      const rect = sky.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      dpr = Math.min(devicePixelRatio || 1, 2);
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const count = Math.min(120, Math.round((w * h) / 15000));
      nodes = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.35,
        vy: (Math.random() - 0.5) * 0.35,
        r: 1 + Math.random() * 1.4,
        c: palette[Math.floor(Math.random() * palette.length)],
        i: Math.floor(Math.random() * palette.length),
      }));
      measureAnchors();
    }

    function frame(advance) {
      if (advance) t++;
      ctx.clearRect(0, 0, w, h);

      // Drift the background stars.
      for (const n of nodes) {
        if (advance) {
          n.x += n.vx;
          n.y += n.vy;
          if (n.x < 0 || n.x > w) n.vx *= -1;
          if (n.y < 0 || n.y > h) n.vy *= -1;
        }
      }

      // Drift the anchors (gentle, size-scaled) and carry the DOM along.
      for (const a of anchors) {
        const dx = a.ampX * Math.sin(t * a.wv + a.px);
        const dy = a.ampY * Math.cos(t * a.wv * 0.85 + a.py);
        a.x = a.homeX + dx;
        a.y = a.homeY + dy;
        if (advance) a.el.style.translate = `${dx.toFixed(2)}px ${dy.toFixed(2)}px`;
      }

      // star <-> star
      for (let a = 0; a < nodes.length; a++) {
        for (let b = a + 1; b < nodes.length; b++) {
          const dx = nodes[a].x - nodes[b].x;
          const dy = nodes[a].y - nodes[b].y;
          const d = Math.hypot(dx, dy);
          if (d < LINK_DIST) {
            ctx.globalAlpha = (1 - d / LINK_DIST) * 0.35;
            ctx.strokeStyle = nodes[a].c;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(nodes[a].x, nodes[a].y);
            ctx.lineTo(nodes[b].x, nodes[b].y);
            ctx.stroke();
          }
        }
      }

      // star <-> gate (anchors pull the web toward themselves)
      for (const a of anchors) {
        for (const n of nodes) {
          const dx = a.x - n.x;
          const dy = a.y - n.y;
          const d = Math.hypot(dx, dy);
          if (d < ANCHOR_LINK) {
            ctx.globalAlpha = (1 - d / ANCHOR_LINK) * 0.5;
            ctx.strokeStyle = a.c;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(n.x, n.y);
            ctx.stroke();
          }
        }
      }

      // gate <-> gate backbone
      for (let a = 0; a < anchors.length; a++) {
        for (let b = a + 1; b < anchors.length; b++) {
          const dx = anchors[a].x - anchors[b].x;
          const dy = anchors[a].y - anchors[b].y;
          const d = Math.hypot(dx, dy);
          if (d < ANCHOR_WEB) {
            ctx.globalAlpha = (1 - d / ANCHOR_WEB) * 0.4;
            ctx.strokeStyle = anchors[a].c;
            ctx.lineWidth = 1.1;
            ctx.beginPath();
            ctx.moveTo(anchors[a].x, anchors[a].y);
            ctx.lineTo(anchors[b].x, anchors[b].y);
            ctx.stroke();
          }
        }
      }

      // background star dots
      ctx.globalAlpha = 0.9;
      for (const n of nodes) {
        ctx.fillStyle = n.c;
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fill();
      }

      // anchor cores (mostly behind the translucent cards; the glow peeks at the edges)
      for (const a of anchors) {
        ctx.save();
        ctx.globalAlpha = 0.85;
        ctx.shadowColor = a.c;
        ctx.shadowBlur = 16;
        ctx.fillStyle = a.c;
        ctx.beginPath();
        ctx.arc(a.x, a.y, a.r, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }

      ctx.globalAlpha = 1;
    }

    function loop() {
      frame(true);
      raf = requestAnimationFrame(loop);
    }

    function start() {
      cancelAnimationFrame(raf);
      if (reduced) {
        // settle into a pleasing static web
        for (let i = 0; i < 60; i++) for (const n of nodes) { n.x += n.vx; n.y += n.vy; }
        frame(false);
      } else {
        loop();
      }
    }

    resize();
    start();

    addEventListener('resize', () => { resize(); start(); });
    // Re-measure once the webfont has swapped (the title's box can shift).
    document.fonts?.ready.then(() => { measureAnchors(); if (reduced) frame(false); });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) cancelAnimationFrame(raf);
      else start();
    });
    // Repaint with the right hues when the theme toggles.
    new MutationObserver(() => {
      palette = PALETTES[document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light'];
      for (const n of nodes) n.c = palette[n.i];
      for (const a of anchors) a.c = palette[a.i];
      if (reduced) frame(false);
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  }
</script>
