---
import { getIcon, type IconName } from '../lib/icons';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

const { name, size = 18, class: className } = Astro.props;
const { viewBox, d } = getIcon(name);
---

<svg
  class:list={['icon', className]}
  width={size}
  height={size}
  viewBox={viewBox}
  fill="currentColor"
  aria-hidden="true"
  focusable="false"
><path d={d} /></svg>
