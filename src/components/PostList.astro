---
import { formatDate, imageUrl, url, type Lang } from '../i18n/ui';
import { slugOf, type Post } from '../lib/blog';

interface Props {
  posts: Post[];
  lang: Lang;
  /** Emit data-facets on each item so the blog index can filter client-side. */
  facetData?: boolean;
  /** Emit data-tags (pipe-separated) so the tag galaxy can filter client-side. */
  tagData?: boolean;
  /** Prefix each title, e.g. "Guide pour <em>title</em>" on the guidepour page. */
  titlePrefix?: string;
}

const { posts, lang, facetData = false, tagData = false, titlePrefix } = Astro.props;
---

<ul class="post-list">
  {posts.map((p) => {
    const href = url(`/${lang}/blog/${slugOf(p)}/`);
    return (
      <li
        data-facets={facetData ? p.data.facets.join(' ') : undefined}
        data-tags={tagData ? p.data.tags.join('|') : undefined}
      >
        <time datetime={p.data.date.toISOString().slice(0, 10)}>{formatDate(p.data.date, lang)}</time>
        {titlePrefix
          ? <a class="post-title" href={href}>{titlePrefix} *{p.data.title}*</a>
          : <a class="post-title" href={href}>{p.data.title}</a>}
        {p.data.image && (
          <a class="post-thumb" href={href} tabindex="-1" aria-hidden="true">
            <img src={imageUrl(p.data.imageThumb ?? p.data.image)} alt="" loading="lazy" decoding="async" />
          </a>
        )}
      </li>
    );
  })}
</ul>
