---
import Base from '../../../layouts/Base.astro';
import PostList from '../../../components/PostList.astro';
import { LANGS, t, url, type Lang } from '../../../i18n/ui';
import { getPosts } from '../../../lib/blog';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const tr = t(lang);
const posts = await getPosts(lang);
const facets = ['dev', 'physics', 'fiction', 'music', 'ideas'] as const;
---

<Base lang={lang} title={tr.blogTitle}>
  <img class="blog-banner" src={url('/assets/images/blog-banner.webp')} alt="" width="1500" height="500" />
  <h1>{tr.blogTitle}</h1>
  <div class="chips" role="group">
    <button class="chip" type="button" data-facet="all" aria-pressed="true">{tr.filterAll}</button>
    {facets.map((f) => (
      <button class="chip" type="button" data-facet={f} aria-pressed="false">{tr.facetNames[f]}</button>
    ))}
  </div>
  <PostList posts={posts} lang={lang} facetData />
</Base>

<style>
  .blog-banner {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 1;
    object-fit: cover;
    border-radius: 0.9rem;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    margin-bottom: 1.5rem;
  }
</style>

<script is:inline>
  const chips = document.querySelectorAll('.chip');
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.setAttribute('aria-pressed', String(c === chip)));
      const facet = chip.dataset.facet;
      document.querySelectorAll('.post-list li').forEach((li) => {
        li.hidden = facet !== 'all' && !(li.dataset.facets || '').split(' ').includes(facet);
      });
    });
  });
</script>
