---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import StarMap from '../../../components/StarMap.astro';
import { formatDate, imageUrl, otherLang, t, url, type Lang } from '../../../i18n/ui';
import { findTwin, gateOf, langOf, slugOf, type Post } from '../../../lib/blog';
import { getRelatedPosts } from '../../../lib/related';

export async function getStaticPaths() {
  const all = await getCollection('blog', ({ data }) => !data.draft);
  return all.map((post) => ({
    params: { lang: langOf(post), slug: slugOf(post) },
    props: { post },
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const lang = langOf(post) as Lang;
const tr = t(lang);
const twin = await findTwin(post);
// Toggle goes to the twin post, or falls back to the other language's blog index.
const twinUrl = twin
  ? url(`/${langOf(twin)}/blog/${slugOf(twin)}/`)
  : url(`/${otherLang(lang)}/blog/`);
const { Content } = await render(post);

// Related posts -> a mini-constellation hung off this post (shared tags + facet,
// sized by relevance). See src/lib/related.ts.
const related = await getRelatedPosts(post, lang);
const myFacets = new Set(post.data.facets);
const relatedStars = related.map((r) => {
  const prefer = r.post.data.facets.find((f) => myFacets.has(f));
  return {
    href: url(`/${lang}/blog/${slugOf(r.post)}/`),
    title: r.post.data.title,
    gate: gateOf(r.post.data.facets, prefer),
    weight: Math.min(1.85, 1 + 0.22 * r.sharedTags),
    image: r.post.data.image ? imageUrl(r.post.data.imageThumb ?? r.post.data.image) : null,
  };
});
---

<Base lang={lang} title={post.data.title} description={post.data.description} twinUrl={twinUrl}>
  <article class="post">
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <time datetime={post.data.date.toISOString().slice(0, 10)}>
        {formatDate(post.data.date, lang)}
      </time>
      {post.data.facets.map((f) => (
        <span class="facet-tag">{tr.facetNames[f]}</span>
      ))}
    </div>
    {twin && <a class="twin-link" href={twinUrl}>{tr.readTwin}</a>}
    {post.data.image && (
      <img class="post-hero" src={imageUrl(post.data.image)} alt="" loading="eager" decoding="async" />
    )}
    <Content />
    <p><a href={url(`/${lang}/blog/`)}>{tr.backToBlog}</a></p>
  </article>

  {relatedStars.length > 0 && (
    <section class="related-constellation">
      <h2 class="section-title">{tr.relatedHeading}</h2>
      <StarMap stars={relatedStars} coreLabel={post.data.title} />
    </section>
  )}
</Base>
