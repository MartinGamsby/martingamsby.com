---
import Base from '../../layouts/Base.astro';
import PostList from '../../components/PostList.astro';
import Constellation from '../../components/Constellation.astro';
import Icon from '../../components/Icon.astro';
import { LANGS, t, url, type Lang } from '../../i18n/ui';
import { getPosts } from '../../lib/blog';
import { perLang, neutral, type Social } from '../../data/socials';
import type { IconName } from '../../lib/icons';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const tr = t(lang);
const latest = (await getPosts(lang)).slice(0, 5);

const icons: Record<string, string> = {
  dev: '<path d="m8 7-5 5 5 5M16 7l5 5-5 5"/>',
  physics:
    '<circle cx="12" cy="12" r="1.8" fill="currentColor" stroke="none"/><ellipse cx="12" cy="12" rx="9.5" ry="4" /><ellipse cx="12" cy="12" rx="9.5" ry="4" transform="rotate(62 12 12)"/>',
  book: '<path d="M12 6.5C10 5 7 4.5 3.5 4.5v13c3.5 0 6.5.5 8.5 2 2-1.5 5-2 8.5-2v-13C17 4.5 14 5 12 6.5Zm0 0v13"/>',
  music:
    '<path d="M9 17.5V6.2l10-2v11.3"/><circle cx="6.8" cy="17.7" r="2.2" fill="currentColor" stroke="none"/><circle cx="16.8" cy="15.7" r="2.2" fill="currentColor" stroke="none"/>',
  everything: '<path d="M12 3.5v17M4.6 7.75l14.8 8.5M19.4 7.75 4.6 16.25"/>',
};

const doors: { key: keyof typeof tr.doors; href: string }[] = [
  { key: 'dev', href: url(`/${lang}/dev/`) },
  { key: 'physics', href: url(`/${lang}/physics/`) },
  { key: 'book', href: url(`/${lang}/book/`) },
  { key: 'music', href: url(`/${lang}/music/`) },
  { key: 'everything', href: url(`/${lang}/blog/`) },
];

// Social links as constellation satellites: each orbits a gate (`facet`) and
// carries a tunable `weight` (node size — 1 = base, bigger = larger & slower).
// Tune these freely; an unmapped label falls back to the "everything" gate.
const ORBIT: Record<string, { facet: string; weight: number }> = {
  GitHub: { facet: 'dev', weight: 1.35 },
  LinkedIn: { facet: 'dev', weight: 1.2 },
  ORCID: { facet: 'physics', weight: 1.15 },
  Zenodo: { facet: 'physics', weight: 1 },
  YouTube: { facet: 'music', weight: 1.25 },
  'X / Twitter': { facet: 'everything', weight: 1 },
  Bluesky: { facet: 'everything', weight: 0.9 },
  Facebook: { facet: 'everything', weight: 0.85 },
  Typeshare: { facet: 'book', weight: 0.95 },
};

const satelliteSources: Social[] = [
  ...perLang[lang],
  ...neutral,
  // Homepage-only: surface the physics preprint right next to the physics gate.
  { label: 'Zenodo', url: 'https://zenodo.org/records/20482196', icon: 'zenodo' as IconName },
];

const satellites = satelliteSources.map((s) => ({
  ...s,
  facet: ORBIT[s.label]?.facet ?? 'everything',
  weight: ORBIT[s.label]?.weight ?? 1,
}));
---

<Base lang={lang} title="Martin Gamsby" description={tr.heroLine}>
  <div class="constellation-field">
    <Constellation />
    <section class="hero">
      <h1>Martin Gamsby</h1>
      <p>{tr.heroLine}</p>
    </section>

    <!--<h2 class="section-title">{tr.doorsHeading}</h2>-->
    <ul class="doors">
      {doors.map((d) => (
        <li>
          <a class={`door door--${d.key}`} href={d.href} data-facet={d.key}>
            <span class="door-icon">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={icons[d.key]}
              />
            </span>
            <strong>{tr.doors[d.key].title}</strong>
            <span>{tr.doors[d.key].blurb}</span>
            <span class="door-go" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>

    <ul class="sky-socials" aria-label={tr.doorsHeading}>
      {satellites.map((s) => (
        <li>
          <a
            class="sky-social"
            href={s.url}
            data-facet={s.facet}
            data-weight={s.weight}
            style={`--w:${s.weight}`}
            target="_blank"
            rel="me noopener"
            aria-label={s.label}
            title={s.label}
          >
            <Icon name={s.icon} size={18} />
          </a>
        </li>
      ))}
    </ul>
  </div>

  <h2 class="section-title">{tr.latestPosts}</h2>
  <PostList posts={latest} lang={lang} />
  <p><a href={url(`/${lang}/blog/`)}>{tr.allPosts} →</a></p>
</Base>
