---
import Base from '../../layouts/Base.astro';
import PostList from '../../components/PostList.astro';
import Constellation from '../../components/Constellation.astro';
import Icon from '../../components/Icon.astro';
import { LANGS, t, url, imageUrl, type Lang } from '../../i18n/ui';
import { getPosts, slugOf } from '../../lib/blog';
import { getGateFeatures } from '../../lib/featured';
import { perLang, neutral } from '../../data/socials';
import { orbit, extraSatellites, type Gate } from '../../data/social-constellation';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const tr = t(lang);
const latest = (await getPosts(lang)).slice(0, 5);

const icons: Record<string, string> = {
  dev: '<path d="m8 7-5 5 5 5M16 7l5 5-5 5"/>',
  physics:
    '<circle cx="12" cy="12" r="1.8" fill="currentColor" stroke="none"/><ellipse cx="12" cy="12" rx="9.5" ry="4" /><ellipse cx="12" cy="12" rx="9.5" ry="4" transform="rotate(62 12 12)"/>',
  book: '<path d="M12 6.5C10 5 7 4.5 3.5 4.5v13c3.5 0 6.5.5 8.5 2 2-1.5 5-2 8.5-2v-13C17 4.5 14 5 12 6.5Zm0 0v13"/>',
  music:
    '<path d="M9 17.5V6.2l10-2v11.3"/><circle cx="6.8" cy="17.7" r="2.2" fill="currentColor" stroke="none"/><circle cx="16.8" cy="15.7" r="2.2" fill="currentColor" stroke="none"/>',
  everything: '<path d="M12 3.5v17M4.6 7.75l14.8 8.5M19.4 7.75 4.6 16.25"/>',
};

const doors: { key: keyof typeof tr.doors; href: string }[] = [
  { key: 'book', href: url(`/${lang}/book/`) },
  { key: 'dev', href: url(`/${lang}/dev/`) },
  { key: 'music', href: url(`/${lang}/music/`) },
  { key: 'physics', href: url(`/${lang}/physics/`) },
  { key: 'everything', href: url(`/${lang}/blog/`) },
];

// One representative post per gate, hung off its door as a "star" in the sky.
// Picked by manual popularity (src/data/post-popularity.json), falling back to
// the most-recent post with an image. See src/lib/featured.ts.
const features = await getGateFeatures(lang, doors.map((d) => d.key) as Gate[]);

// Which social orbits which gate, and how big, is configured in
// src/data/social-constellation.ts — edit that file to tune the icons.
const satellites = [
  ...[...perLang[lang], ...neutral].map((s) => ({
    label: s.label,
    url: s.url,
    icon: s.icon,
    facet: orbit[s.label]?.gate ?? 'everything',
    weight: orbit[s.label]?.size ?? 1,
  })),
  ...extraSatellites.map((s) => ({
    label: s.label,
    url: s.url,
    icon: s.icon,
    facet: s.gate,
    weight: s.size,
  })),
];
---

<Base lang={lang} title="Martin Gamsby" description={tr.heroLine}>
  <div class="constellation-field">
    <Constellation />
    <section class="hero">
      <h1>Martin Gamsby</h1>
      <p>{tr.heroLine}</p>
    </section>

    <!--<h2 class="section-title">{tr.doorsHeading}</h2>-->
    <ul class="doors">
      {doors.map((d) => (
        <li>
          <a class={`door door--${d.key}`} href={d.href} data-facet={d.key}>
            <span class="door-icon">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={icons[d.key]}
              />
            </span>
            <strong>{tr.doors[d.key].title}</strong>
            <span>{tr.doors[d.key].blurb}</span>
            <span class="door-go" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>

    <ul class="sky-socials" aria-label={tr.doorsHeading}>
      {satellites.map((s) => (
        <li>
          <a
            class="sky-social"
            href={s.url}
            data-facet={s.facet}
            data-weight={s.weight}
            style={`--w:${s.weight}`}
            target="_blank"
            rel="me noopener"
            aria-label={s.label}
            title={s.label}
          >
            <Icon name={s.icon} size={18} />
          </a>
        </li>
      ))}
      <!-- remove that part if you don't wat articles anymore... -->
      {features.map((f) => {
        const href = url(`/${lang}/blog/${slugOf(f.post)}/`);
        const thumb = f.post.data.image ? imageUrl(f.post.data.imageThumb ?? f.post.data.image) : null;
        return (
          <li>
            <a
              class="sky-social sky-post"
              href={href}
              data-facet={f.gate}
              data-weight="1.9"
              style="--w:1.9"
              aria-label={f.post.data.title}
              title={f.post.data.title}
            >
              {thumb
                ? <img src={thumb} alt="" loading="eager" decoding="async" />
                : <span class="sky-post-glyph" aria-hidden="true">★</span>}
            </a>
          </li>
        );
      })}
    </ul>
  </div>

  <h2 class="section-title">{tr.latestPosts}</h2>
  <PostList posts={latest} lang={lang} />
  <p><a href={url(`/${lang}/blog/`)}>{tr.allPosts} →</a></p>
</Base>
