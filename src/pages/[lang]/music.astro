---
import Base from '../../layouts/Base.astro';
import DoorStub from '../../components/DoorStub.astro';
import { LANGS, t, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const tr = t(lang);
const links =
  lang === 'fr'
    ? [{ label: 'YouTube — @MartinGamsby', url: 'https://www.youtube.com/@MartinGamsby' }]
    : [{ label: 'YouTube — @MartinGamsbyEN', url: 'https://www.youtube.com/@MartinGamsbyEN' }];
---

<Base lang={lang} title={tr.doors.music.title}>
  <DoorStub lang={lang} doorKey="music" facet="music" links={links} />
</Base>
